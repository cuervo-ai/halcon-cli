    -webkit-mask-image: radial-gradient(ellipse 78% 68% at 58% -8%, black 18%, transparent 72%);
    pointer-events: none;
  }

  /* Hero terminal — 3D initial perspective tilt */
  #hero-terminal {
    transform: perspective(1100px) rotateX(4deg) rotateY(-2.5deg) translateZ(0);
    transition: transform 650ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
  .hero-terminal-col:hover #hero-terminal {
    transform: perspective(1100px) rotateX(0.5deg) rotateY(-0.5deg) translateZ(0);
  }

  /* Physical 3D depth on primary CTA buttons */
  .btn-primary {
    box-shadow:
      0 4px 0 rgba(110, 8, 0, 0.80),
      0 6px 20px rgba(232,82,0,0.24);
    transition: transform 120ms ease, box-shadow 120ms ease, filter 120ms ease !important;
  }
  .btn-primary:hover {
    transform: translateY(-2px) !important;
    box-shadow:
      0 6px 0 rgba(110, 8, 0, 0.80),
      0 12px 32px rgba(232,82,0,0.38),
      0 0 64px -12px rgba(232,82,0,0.26) !important;
    filter: brightness(1.08) !important;
  }
  .btn-primary:active {
    transform: translateY(2px) !important;
    box-shadow:
      0 1px 0 rgba(110, 8, 0, 0.80),
      0 2px 6px rgba(232,82,0,0.12) !important;
    filter: brightness(0.96) !important;
  }

  /* Showcase panel enter animation */
  @keyframes panel-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .showcase-panel.active {
    animation: panel-in 0.26s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  /* CSS-native scroll animations — progressive enhancement (Chrome 115+) */
  @supports (animation-timeline: view()) and (animation-range: entry 0%) {
    @keyframes reveal-view-native {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    [data-reveal] {
      opacity: 1 !important;
      transform: translateY(0) !important;
      transition: none !important;
      animation: reveal-view-native 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-timeline: view(block);
      animation-range: entry 0% entry 30%;
    }
    [data-delay="1"] { animation-delay: 0s !important; }
    [data-delay="2"] { animation-delay: 0s !important; }
    [data-delay="3"] { animation-delay: 0s !important; }
    [data-delay="4"] { animation-delay: 0s !important; }
    [data-delay="5"] { animation-delay: 0s !important; }
    [data-delay="6"] { animation-delay: 0s !important; }
  }

  /* content-visibility for render performance on long sections */
  .cv-section {
    content-visibility: auto;
    contain-intrinsic-size: 0 680px;
  }

  /* Magnetic button touch target */
  [data-magnetic] {
    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Provider card hover depth — uses per-provider --p-glow */
  .provider-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 16px 48px rgba(0,0,0,0.40),
      0 0 32px rgba(var(--p-glow), 0.12),
      inset 0 1px 0 rgba(var(--p-glow), 0.15);
  }
</style>

<script>
  // ── Typewriter ────────────────────────────────────────────
  function initTypewriter() {
    const el = document.getElementById('hero-typewriter');
    if (!el) return;
    const phrases = [
      'that runs on any model.',
      'for Claude & GPT-4o.',
      'with 21 built-in tools.',
      'with layered permissions.',
      'for your whole team.',
    ];
    let wi = 0, ci = 0, erasing = false;
    function tick() {
      const word = phrases[wi];
      if (!erasing) {
        el.textContent = word.slice(0, ++ci);
        if (ci >= word.length) { erasing = true; setTimeout(tick, 2400); return; }
      } else {
        el.textContent = word.slice(0, --ci);
        if (ci <= 0) { erasing = false; wi = (wi + 1) % phrases.length; setTimeout(tick, 320); return; }
      }
      setTimeout(tick, erasing ? 36 : 52 + Math.random() * 28);
    }
    tick();
  }

  // ── Install tabs ──────────────────────────────────────────
  function initTabs() {
    document.querySelectorAll('.install-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.install-tab').forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        const cmd   = btn.getAttribute('data-cmd')   || '';
        const label = btn.getAttribute('data-label') || 'bash';
        const cmdEl = document.getElementById('hero-cmd-text');
        const lblEl = document.getElementById('hero-tab-label');
        if (cmdEl) cmdEl.textContent = cmd;
        if (lblEl) lblEl.textContent = label;
      });
    });
  }

  // ── Copy button ───────────────────────────────────────────
  function initCopy() {
    const btn = document.getElementById('hero-copy-btn');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      const raw = document.getElementById('hero-cmd-text')?.textContent || '';
      const text = raw;
      try {
        await navigator.clipboard.writeText(text);
        const svg = btn.querySelector('svg');
        if (svg) {
          svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>';
          setTimeout(() => {
            svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>';
          }, 1500);
        }
      } catch {}
    });
  }

  // ── Terminal clock ────────────────────────────────────────
  function initClock() {
    const el = document.getElementById('hero-term-clock') as HTMLTimeElement | null;
    if (!el) return;
    function tick() {
      const now = new Date();
      el.textContent = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
      el.setAttribute('datetime', now.toISOString());
    }
    tick();
    setInterval(tick, 1000);
  }

  // ── Video observer ────────────────────────────────────────
  function initVideo() {
    const v = document.getElementById('hero-video') as HTMLVideoElement | null;
    if (!v) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) { v.pause(); return; }
    const obs = new IntersectionObserver(
      entries => entries.forEach(e => e.isIntersecting ? v.play().catch(() => {}) : v.pause()),
      { threshold: 0.15 }
    );
    obs.observe(v);
  }

  // ── Spark particles ───────────────────────────────────────
  function initSparks(colors: string[]) {
    const container = document.getElementById('hero-sparks');
    if (!container || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    container.innerHTML = '';
    const n = 16;
    for (let i = 0; i < n; i++) {
      const el = document.createElement('div');
      const size   = 1.2 + Math.random() * 2.8;
      const x      = 38 + Math.random() * 54;
      const bottom = 4  + Math.random() * 35;
      const delay  = Math.random() * 7;
      const dur    = 4.5 + Math.random() * 5.5;
      const tx     = (Math.random() - 0.45) * 55;
      const color  = colors[Math.floor(Math.random() * colors.length)] || '#a00e00';
      el.style.cssText = `
        position:absolute;left:${x}%;bottom:${bottom}%;
        width:${size}px;height:${size}px;border-radius:50%;
        background:${color};opacity:0;
        --op:${0.45 + Math.random() * 0.40};
        --op2:${0.12 + Math.random() * 0.18};
        --tx:${tx}px;
        animation:spark-rise ${dur}s ease-out ${delay}s infinite;
        filter:blur(${size > 3 ? '0.6px' : '0px'});
      `;
      container.appendChild(el);
    }
  }

  // ── MOMOTO: safe usage — only shiftColor + BRAND_* constants ──
  // Rationale: TokenDerivationEngine::derive_states() is calibrated for TUI Falcon Blue
  // palette, not fire orange. We use only arithmetic shiftColor for background glows.
  // CSS custom properties drive all brand identity colors.
  async function initHeroMomoto() {
    try {
      const {
        shiftColor,
        checkContrast, isAccessible,
        BRAND_FIRE, BRAND_EMBER, BRAND_GOLD, BRAND_SPARK, BRAND_BG, BRAND_TEXT1,
      } = await import('../lib/momoto/index');

      // Safe: shiftColor does arithmetic OKLCH shift, no derive_states
      // BRAND_EMBER is a ColorOklch object: {l, c, h}
      const rubyShifted = await shiftColor(BRAND_EMBER, { lightness: -0.08, chroma: 0.06, hue: -10 });
      const rubyDeep    = await shiftColor(BRAND_EMBER, { lightness: -0.18, chroma: 0.04, hue: -14 });
      const fireShifted = await shiftColor(BRAND_FIRE, { lightness: 0.04, chroma: 0.01, hue: 4 });
      const goldShifted = await shiftColor(BRAND_GOLD, { lightness: 0.03, chroma: -0.01 });

      // Apply to decorative background glow layers
      const glowRuby = document.getElementById('hero-glow-ruby');
      const glowFire = document.getElementById('hero-glow-fire');
      const glowGold = document.getElementById('hero-glow-gold');
      const termAura = document.getElementById('hero-term-aura');

      if (glowRuby && rubyDeep) glowRuby.style.background =
        `radial-gradient(ellipse 88% 68% at 65% 42%, ${rubyDeep}44 0%, ${rubyShifted}1a 38%, transparent 62%)`;
      if (glowFire && fireShifted) glowFire.style.background =
        `radial-gradient(ellipse 52% 58% at 20% 68%, ${fireShifted}1a 0%, transparent 58%)`;
      if (glowGold && goldShifted) glowGold.style.background =
        `radial-gradient(ellipse 42% 32% at 72% 8%, ${goldShifted}10 0%, transparent 52%)`;
      if (termAura && rubyDeep) termAura.style.background =
        `radial-gradient(ellipse at center, ${rubyDeep}1e 0%, transparent 70%)`;

      // Headline: shift fire+gold for gradient endpoints
      const headline = document.getElementById('hero-headline-brand');
      if (headline && fireShifted && goldShifted) {
        headline.style.backgroundImage =
          `linear-gradient(135deg, ${goldShifted} 0%, ${fireShifted} 48%, ${rubyShifted} 100%)`;
      }

      // Sparks with momoto-derived colors
      if (rubyDeep && rubyShifted && fireShifted && goldShifted) {
        initSparks([rubyDeep, rubyShifted, fireShifted, goldShifted, '#a00e00']);
      } else {
        initSparks(['#a00e00', '#e85200', '#f5a000', '#c41400']);
      }

      // Passive accessibility validation only
      checkContrast(BRAND_TEXT1, BRAND_BG).then(contrast => {
        if (!contrast.passesAA) {
          console.warn('[Momoto] WCAG AA contrast check failed:', contrast);
        }
      });
      isAccessible(BRAND_TEXT1, BRAND_BG).catch(() => {});

    } catch (_e) {
      // Fallback: static fire colors
      initSparks(['#a00e00', '#e85200', '#f5a000', '#c41400']);
    }
  }

  // ── Scroll progress bar ───────────────────────────────────
  function initScrollProgress() {
    const bar = document.createElement('div');
    bar.id = 'scroll-progress';
    document.body.prepend(bar);
    const update = () => {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const pct = max > 0 ? Math.min((window.scrollY / max) * 100, 100) : 0;
      bar.style.width = pct + '%';
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  // ── Scroll reveal observer ────────────────────────────────
  function initReveal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('[data-reveal]').forEach(el => el.classList.add('revealed'));
      return;
    }
    const obs = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          obs.unobserve(e.target);
        }
      }),
      { threshold: 0.06, rootMargin: '0px 0px -48px 0px' }
    );
    document.querySelectorAll('[data-reveal]').forEach(el => obs.observe(el));
  }

  // ── Card 3D tilt effect ───────────────────────────────────
  function initTilt() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    document.querySelectorAll('[data-tilt]').forEach(card => {
      const el = card as HTMLElement;
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width  - 0.5;
        const y = (e.clientY - rect.top)  / rect.height - 0.5;
        el.style.transition = 'transform 0.08s ease';
        el.style.transform  = `perspective(700px) rotateX(${-y * 6}deg) rotateY(${x * 6}deg) translateY(-1px)`;
      });
      el.addEventListener('mouseleave', () => {
        el.style.transition = 'transform 0.4s cubic-bezier(0.22,1,0.36,1)';
        el.style.transform  = '';
      });
    });
  }

  // ── Command Showcase tabs ─────────────────────────────────
  function initShowcase() {
    document.querySelectorAll('.showcase-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = btn.getAttribute('data-tab');
        document.querySelectorAll('.showcase-tab').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.showcase-panel').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        const panel = document.querySelector(`.showcase-panel[data-panel="${idx}"]`);
        if (panel) panel.classList.add('active');
      });
    });
  }

  // ── Stat count-up animation ───────────────────────────────
  function initStatCountup() {
    const targets: Record<string, number> = { '21': 21, '5': 5, '100%': 100, '<2ms': 2 };
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const card = e.target as HTMLElement;
        const numEl = card.querySelector('.stat-number') as HTMLElement | null;
        if (!numEl || card.classList.contains('counted')) return;
        card.classList.add('counted');
        const text = numEl.textContent?.trim() || '';
        if (text === '21' || text === '5') {
          const target = Number(text);
          const dur = 800;
          const start = performance.now();
          const update = (now: number) => {
            const t = Math.min((now - start) / dur, 1);
            const ease = 1 - Math.pow(1 - t, 3);
            numEl.textContent = String(Math.round(ease * target));
            if (t < 1) requestAnimationFrame(update);
            else numEl.textContent = String(target);
          };
          requestAnimationFrame(update);
        }
        obs.unobserve(card);
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('.stat-card').forEach(c => obs.observe(c));
  }

  // ── Magnetic button effect (2026 SOTA) ────────────────────
  function initMagneticButtons() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    document.querySelectorAll('[data-magnetic]').forEach(btn => {
      const el = btn as HTMLElement;
      let rafId = 0;
      el.addEventListener('mousemove', (e: MouseEvent) => {
        cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(() => {
          const rect = el.getBoundingClientRect();
          const x = (e.clientX - rect.left - rect.width  / 2) * 0.30;
          const y = (e.clientY - rect.top  - rect.height / 2) * 0.30;
          el.style.transform = `translate(${x}px, ${y}px)`;
        });
      });
      el.addEventListener('mouseleave', () => {
        cancelAnimationFrame(rafId);
        el.style.transform = '';
      });
    });
  }

  // ── Boot ──────────────────────────────────────────────────
  function initHero() {
    initTypewriter();
    initTabs();
    initCopy();
    initClock();
    initVideo();
    initHeroMomoto();
    initScrollProgress();
    initReveal();
    initTilt();
    initShowcase();
    initStatCountup();
    initMagneticButtons();
  }

  initHero();
  document.addEventListener('astro:after-swap', initHero);
</script>
