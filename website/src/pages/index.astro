---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/translations';

const lang = 'en';

// Provider SVG icons — clean line icons, stroke-width 1.5, optimized for 20–22px display
const providerIcons: Record<string, string> = {
  // Anthropic: stylized A / triangular prism — their logomark shape
  anthropic: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M5 20L12 4l7 16"/>
    <path d="M8.5 14h7"/>
  </svg>`,
  // OpenAI: clean hexagon with center dot — represents their logo geometry
  openai: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 2l8.66 5v10L12 22 3.34 17V7z"/>
    <circle cx="12" cy="12" r="2.5" fill="currentColor" stroke="none"/>
  </svg>`,
  // DeepSeek: compass / magnifying lens — "deep seek" / search
  deepseek: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="7"/>
    <path d="M16.5 16.5L21 21"/>
    <circle cx="11" cy="11" r="3" fill="currentColor" stroke="none" opacity="0.5"/>
  </svg>`,
  // Google Gemini: 4-pointed star / gemstone — Gemini's actual logomark
  gemini: `<svg viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
    <path d="M12 2C12 7 17 12 22 12C17 12 12 17 12 22C12 17 7 12 2 12C7 12 12 7 12 2Z"/>
  </svg>`,
  // Ollama: simple server/terminal — local model runner
  ollama: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="2" y="3" width="20" height="14" rx="2"/>
    <path d="M8 21h8M12 17v4"/>
    <path d="M7 8l2 2-2 2M13 10h4"/>
  </svg>`,
};

const providers = [
  {
    name: 'Anthropic',
    logoKey: 'anthropic',
    accent: 'rgba(232,82,0,0.10)',
    border: 'rgba(232,82,0,0.30)',
    glow: '232,82,0',
    models: ['Claude Opus 4.6', 'Claude Sonnet 4.5', 'Claude Haiku 4.5'],
    badge: null,
  },
  {
    name: 'OpenAI',
    logoKey: 'openai',
    accent: 'rgba(16,163,127,0.10)',
    border: 'rgba(16,163,127,0.28)',
    glow: '16,163,127',
    models: ['GPT-4o', 'GPT-4o mini', 'o1', 'o3-mini'],
    badge: null,
  },
  {
    name: 'DeepSeek',
    logoKey: 'deepseek',
    accent: 'rgba(99,102,241,0.10)',
    border: 'rgba(99,102,241,0.28)',
    glow: '99,102,241',
    models: ['deepseek-chat', 'deepseek-coder', 'deepseek-reasoner'],
    badge: null,
  },
  {
    name: 'Google Gemini',
    logoKey: 'gemini',
    accent: 'rgba(66,133,244,0.10)',
    border: 'rgba(66,133,244,0.28)',
    glow: '66,133,244',
    models: ['Gemini 2.0 Flash', 'Gemini 2.5 Pro'],
    badge: null,
  },
  {
    name: 'Ollama',
    logoKey: 'ollama',
    accent: 'rgba(245,160,0,0.08)',
    border: 'rgba(245,160,0,0.28)',
    glow: '245,160,0',
    models: ['Llama 3', 'Mistral', 'DeepSeek Coder V2', '+ any model'],
    badge: t(lang, 'providers.local_badge'),
  },
];
---

<Layout
  title={t(lang, 'meta.index.title')}
  description={t(lang, 'meta.index.desc')}
  lang={lang}
>

  <!-- ═══════════════════════════════════════════ HERO ══ -->
  <section class="hero-root relative min-h-screen flex items-center pt-20 pb-8 overflow-hidden">

    <!-- ── FONDO MOMOTO RUBY ─────────────────────────────── -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div id="hero-glow-ruby"
           style="position:absolute;inset:0;background:radial-gradient(ellipse 85% 65% at 65% 42%, rgba(160,14,0,0.28) 0%, transparent 62%);"></div>
      <div id="hero-glow-fire"
           style="position:absolute;inset:0;background:radial-gradient(ellipse 50% 55% at 22% 65%, rgba(232,82,0,0.10) 0%, transparent 58%);"></div>
      <div id="hero-glow-gold"
           style="position:absolute;inset:0;background:radial-gradient(ellipse 40% 30% at 70% 10%, rgba(245,160,0,0.06) 0%, transparent 55%);"></div>
      <!-- Ambient beam — diagonal light sweep -->
      <div class="hero-beam" aria-hidden="true"></div>
      <div class="hero-grain absolute inset-0" style="opacity:0.030;"></div>
      <div class="absolute inset-0 bg-grid" style="opacity:0.038;"></div>
      <div class="bg-dots absolute inset-0" aria-hidden="true"></div>
      <div id="hero-sparks" class="absolute inset-0 overflow-hidden"></div>
    </div>

    <!-- ── LAYOUT 2 COLUMNAS ─────────────────────────────── -->
    <div class="relative z-10 max-w-7xl mx-auto w-full px-5 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-center">

        <!-- ── IZQUIERDA: texto ──────────────────────────── -->
        <div class="text-center lg:text-left">

          <!-- Badge -->
          <div id="hero-badge" data-reveal
               class="inline-flex items-center gap-2 px-3.5 py-1.5 mb-7 rounded-full border font-mono text-xs font-medium"
               style="border-color:rgba(232,82,0,0.30);background:rgba(232,82,0,0.07);color:var(--c-gold);animation:badge-breathe 3.6s ease-in-out infinite;">
            <span style="width:6px;height:6px;border-radius:50%;background:var(--c-p);animation:live-pulse 2.3s ease-in-out infinite;display:inline-block;"></span>
            v0.3.0
            <span style="font-size:10px;padding:1px 6px;border-radius:4px;background:rgba(245,160,0,0.09);color:var(--c-t3);">stable</span>
          </div>

          <!-- Headline -->
          <h1 data-reveal data-delay="1" class="text-5xl sm:text-6xl lg:text-[4.2rem] xl:text-7xl font-black leading-[1.02] tracking-tight mb-5 font-display">
            <span class="block" style="color:var(--c-t1);">The terminal AI agent</span>
            <span id="hero-headline-brand" class="block mt-1"
                  style="background-image:linear-gradient(135deg,var(--c-gold) 0%,var(--c-p) 48%,var(--c-ember) 100%);
                         background-size:200% auto;-webkit-background-clip:text;background-clip:text;
                         -webkit-text-fill-color:transparent;color:transparent;
                         animation:gradient-shift 5s ease infinite;">
              <span id="hero-typewriter"></span><span id="hero-cursor"
                    style="-webkit-text-fill-color:var(--c-p);color:var(--c-p);animation:cursor-blink 1.1s step-end infinite;">▋</span>
            </span>
          </h1>

          <!-- Subheadline -->
          <p data-reveal data-delay="2" class="text-base sm:text-lg leading-relaxed max-w-xl mx-auto lg:mx-0 mb-8"
             style="color:var(--c-t2);">
            {t(lang, 'hero.sub')}
          </p>

          <!-- CTAs -->
          <div data-reveal data-delay="3" class="flex flex-col sm:flex-row items-center lg:items-start justify-center lg:justify-start gap-3 mb-8">
            <a href="/download" class="btn-primary" data-magnetic style="padding:0.875rem 1.75rem;font-size:0.9375rem;">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                      d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
              </svg>
              Download v0.3.0
            </a>
            <a href="/docs" class="btn-outline" style="padding:0.875rem 1.75rem;font-size:0.9375rem;">
              Read the docs
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>

          <!-- Install tabs -->
          <div data-reveal data-delay="4" class="max-w-lg mx-auto lg:mx-0">
            <div class="flex gap-1 mb-2" role="tablist" aria-label="Install method">
              <button class="install-tab active" role="tab" aria-selected="true"
                      data-cmd="curl -sSfL https://halcon.cuervo.cloud/install.sh | sh" data-label="bash">curl</button>
              <button class="install-tab" role="tab" aria-selected="false"
                      data-cmd="brew tap cuervo-ai/tap &amp;&amp; brew install halcon" data-label="brew">brew</button>
              <button class="install-tab" role="tab" aria-selected="false"
                      data-cmd="cargo install --git https://github.com/cuervo-ai/halcon-cli halcon-cli" data-label="cargo">cargo</button>
            </div>
            <div class="glass rounded-xl overflow-hidden text-left" style="border-color:rgba(232,82,0,0.14);">
              <div class="flex items-center justify-between px-4 py-2 border-b"
                   style="border-color:var(--c-b);background:var(--c-surface);">
                <div class="flex gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,96,89,0.55);"></span>
                  <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(255,189,68,0.55);"></span>
                  <span class="w-2.5 h-2.5 rounded-full" style="background:rgba(40,200,64,0.55);"></span>
                </div>
                <span id="hero-tab-label" class="text-xs font-mono" style="color:var(--c-t4);">bash</span>
              </div>
              <div class="px-4 py-3.5 font-mono text-sm flex items-center justify-between gap-3"
                   style="color:var(--c-p);">
                <div>
                  <span style="color:var(--c-t4);">$ </span>
                  <span id="hero-cmd-text">curl -sSfL https://halcon.cuervo.cloud/install.sh | sh</span>
                </div>
                <button id="hero-copy-btn" title="Copy"
                        class="flex-shrink-0 p-1.5 rounded transition-colors"
                        style="color:var(--c-t4);"
                        onmouseover="this.style.color='var(--c-t1)';this.style.background='rgba(232,82,0,0.08)'"
                        onmouseout="this.style.color='var(--c-t4)';this.style.background='transparent'">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                  </svg>
                </button>
              </div>
            </div>
            <p class="text-xs mt-2 text-center lg:text-left" style="color:var(--c-t4);">
              SHA-256 verified · no sudo · installs to ~/.local/bin
            </p>
          </div>

          <!-- Trust row -->
          <div data-reveal data-delay="5" class="flex items-center justify-center lg:justify-start gap-x-3 gap-y-1 mt-7 flex-wrap"
               aria-label="Platform support">
            <span class="font-mono text-xs font-semibold" style="color:var(--c-p);">v0.3.0</span>
            <span style="color:var(--c-t4);" aria-hidden="true">·</span>
            <span class="text-xs" style="color:var(--c-t3);">macOS</span>
            <span style="color:var(--c-t4);" aria-hidden="true">·</span>
            <span class="text-xs" style="color:var(--c-t3);">Linux</span>
            <span style="color:var(--c-t4);" aria-hidden="true">·</span>
            <span class="text-xs" style="color:var(--c-t3);">Windows</span>
            <span style="color:var(--c-t4);" aria-hidden="true">·</span>
            <span class="text-xs font-mono" style="color:var(--c-t4);">Written in Rust</span>
          </div>
        </div>

        <!-- ── DERECHA: terminal video ────────────────────── -->
        <div class="relative hero-terminal-col" data-reveal data-delay="2">
          <div id="hero-term-aura" class="absolute -inset-4 rounded-3xl pointer-events-none"
               style="background:radial-gradient(ellipse at center,rgba(160,14,0,0.12) 0%,transparent 70%);filter:blur(24px);"></div>

          <div id="hero-terminal" class="relative rounded-2xl overflow-hidden"
               style="border:1px solid rgba(200,30,0,0.22);background:var(--c-surface-2);
                      box-shadow:0 0 50px rgba(160,14,0,0.18),0 0 100px rgba(160,14,0,0.08),0 24px 60px rgba(0,0,0,0.55);">

            <div class="flex items-center gap-1.5 px-4 py-2.5 border-b select-none"
                 style="border-color:rgba(200,30,0,0.10);background:var(--c-surface);">
              <span class="term-dot w-3 h-3 rounded-full" style="background:rgba(255,96,89,0.65);" title="Close"></span>
              <span class="term-dot w-3 h-3 rounded-full" style="background:rgba(255,189,68,0.65);" title="Minimize"></span>
              <span class="term-dot w-3 h-3 rounded-full" style="background:rgba(40,200,64,0.65);" title="Zoom"></span>
              <span class="flex-1 text-center font-mono text-xs" style="color:var(--c-t4);">halcon — zsh — 120×38</span>
              <time id="hero-term-clock" class="font-mono text-xs tabular-nums"
                    style="color:var(--c-t4);min-width:5ch;"></time>
            </div>

            <div class="hero-scanlines absolute inset-0 z-10 pointer-events-none rounded-b-2xl"></div>

            <div class="absolute z-20 pointer-events-none"
                 style="top:40px;left:0;right:0;height:13%;
                        background:linear-gradient(to bottom,var(--c-surface-2) 0%,transparent 100%);"></div>
            <div class="absolute bottom-0 z-20 pointer-events-none"
                 style="left:0;right:0;height:7%;
                        background:linear-gradient(to top,var(--c-surface-2) 0%,transparent 100%);"></div>

            <video id="hero-video" autoplay muted loop playsinline
                   class="w-full block" poster="/terminal-uxui.png"
                   style="display:block;max-height:480px;object-fit:cover;object-position:top;">
              <source src="/hero.mp4" type="video/mp4" />
            </video>
          </div>

          <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-3/4 h-16 pointer-events-none"
               style="background:radial-gradient(ellipse,rgba(160,14,0,0.22) 0%,transparent 68%);filter:blur(18px);"></div>

          <!-- Floating feature chips -->
          <div class="hero-chips-layer" aria-hidden="true">
            <div class="hero-chip" style="top:-16px;right:10%;animation-delay:0s;">
              <span style="color:var(--c-p);">⚡</span> 21 Built-in Tools
            </div>
            <div class="hero-chip" style="bottom:12%;left:-5%;animation-delay:1.4s;">
              <span style="color:var(--c-gold);">◎</span> Multi-model
            </div>
            <div class="hero-chip" style="top:40%;right:-8%;animation-delay:0.8s;">
              <span style="color:var(--c-spark);">🦀</span> 100% Rust
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ STATS ══ -->
  <section class="py-16 px-4 border-t" style="border-color: var(--c-b);">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">

        <div class="stat-card" data-reveal>
          <div class="stat-number font-display font-black" style="color:var(--c-p);">21</div>
          <div class="stat-label" style="color:var(--c-t3);">Built-in Tools</div>
          <div class="stat-bar mt-3">
            <div class="stat-bar-fill" style="width:88%;background:linear-gradient(90deg,var(--c-ember),var(--c-p));"></div>
          </div>
        </div>

        <div class="stat-card" data-reveal data-delay="1">
          <div class="stat-number font-display font-black" style="color:var(--c-gold);">5</div>
          <div class="stat-label" style="color:var(--c-t3);">AI Providers</div>
          <div class="stat-bar mt-3">
            <div class="stat-bar-fill" style="width:65%;background:linear-gradient(90deg,var(--c-p),var(--c-gold));"></div>
          </div>
        </div>

        <div class="stat-card" data-reveal data-delay="2">
          <div class="stat-number font-display font-black" style="background:linear-gradient(135deg,var(--c-gold),var(--c-p));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;">100%</div>
          <div class="stat-label" style="color:var(--c-t3);">Written in Rust</div>
          <div class="stat-bar mt-3">
            <div class="stat-bar-fill" style="width:100%;background:linear-gradient(90deg,var(--c-ember),var(--c-gold));"></div>
          </div>
        </div>

        <div class="stat-card" data-reveal data-delay="3">
          <div class="stat-number font-display font-black" style="color:var(--c-spark);">&lt;2ms</div>
          <div class="stat-label" style="color:var(--c-t3);">Agent overhead</div>
          <div class="stat-bar mt-3">
            <div class="stat-bar-fill" style="width:98%;background:linear-gradient(90deg,var(--c-p),var(--c-spark));"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ PROVIDERS ══ -->
  <section id="providers" class="cv-section py-24 px-4 border-t" style="border-color: var(--c-b);">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-14" data-reveal>
        <p class="text-xs font-mono uppercase tracking-widest mb-3" style="color:var(--c-p);">Multi-model</p>
        <h2 class="text-3xl sm:text-4xl font-black mb-3 font-display">{t(lang, 'providers.heading')}</h2>
        <p class="text-base" style="color: var(--c-t3);">{t(lang, 'providers.sub')}</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {providers.map((p, i) => (
          <div class="glass rounded-2xl provider-card"
               data-reveal
               data-delay={String(i + 1)}
               data-tilt
               style={`border-color: ${p.border}; background: ${p.accent}; --p-glow: ${p.glow};`}>
            <!-- Top accent strip -->
            <div class="provider-top-strip" style={`background: linear-gradient(90deg, rgba(${p.glow},0.55) 0%, rgba(${p.glow},0.0) 100%);`}></div>
            <div class="p-5 pt-4">
              <!-- Header -->
              <div class="flex items-start justify-between mb-4">
                <div class="flex items-center gap-3">
                  <div class="w-11 h-11 rounded-xl flex items-center justify-center provider-icon"
                       style={`background: rgba(${p.glow},0.14); border: 1px solid rgba(${p.glow},0.32); color: rgba(${p.glow},1);`}
                       set:html={providerIcons[p.logoKey]}>
                  </div>
                  <span class="font-bold text-base" style="color: var(--c-t1);">{p.name}</span>
                </div>
                {p.badge && (
                  <span class="text-xs font-medium px-2 py-0.5 rounded-full"
                        style={`background: rgba(${p.glow},0.15); color: rgba(${p.glow},1); border: 1px solid rgba(${p.glow},0.35);`}>
                    {p.badge}
                  </span>
                )}
              </div>
              <!-- Divider -->
              <div class="provider-divider" style={`background: linear-gradient(90deg, rgba(${p.glow},0.30) 0%, transparent 100%);`}></div>
              <!-- Models -->
              <div class="space-y-1.5 mt-3">
                <p class="text-xs uppercase tracking-wider mb-2 font-mono" style="color: var(--c-t4);">{t(lang, 'providers.models')}</p>
                {p.models.map(m => (
                  <div class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: rgba(${p.glow},0.80);`}></span>
                    <span class="font-mono text-xs" style="color: var(--c-t2);">{m}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}

        <!-- Switch card -->
        <div class="glass rounded-2xl p-6 flex flex-col items-center justify-center text-center gap-4 provider-switch-card"
             data-reveal data-delay="6"
             style="border-style: dashed; border-color: rgba(200,80,0,0.25);">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center"
               style="background: rgba(232,82,0,0.10); border: 1px solid rgba(232,82,0,0.25);">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--c-p);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
            </svg>
          </div>
          <p class="text-sm font-semibold" style="color: var(--c-t1);">Switch with one flag</p>
          <div class="w-full space-y-2">
            <div class="provider-code-block" style="border-color: rgba(232,82,0,0.20);">
              <span class="provider-code-label" style="color: var(--c-p);">provider</span>
              <code class="font-mono text-xs" style="color: var(--c-t2);">halcon -p openai chat</code>
            </div>
            <div class="provider-code-block" style="border-color: rgba(245,160,0,0.20);">
              <span class="provider-code-label" style="color: var(--c-gold);">model</span>
              <code class="font-mono text-xs" style="color: var(--c-t2);">halcon -p ollama -m llama3 chat</code>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ FEATURES BENTO ══ -->
  <section id="features" class="cv-section py-24 px-4 border-t" style="border-color: var(--c-b);">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-14" data-reveal>
        <p class="text-xs font-mono uppercase tracking-widest mb-3" style="color:var(--c-p);">Capabilities</p>
        <h2 class="text-3xl sm:text-4xl font-black mb-3 font-display">{t(lang, 'features.heading')}</h2>
        <p class="text-base" style="color: var(--c-t3);">{t(lang, 'features.sub')}</p>
      </div>

      <!-- Bento grid: [F1:2] [F2:1] / [F3:1] [F4:1] [F5:1] / [F6:3] -->
      <div class="bento-grid">

        <!-- F1: 21 tools — LARGE with mini tool stream preview -->
        <div class="bento-2 glass rounded-2xl p-7 bento-card" data-reveal data-tilt>
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5"
