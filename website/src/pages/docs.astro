---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/translations';

const lang = 'en';

const sections = [
  {
    title: "Getting Started",
    items: [
      { title: "Installation",       anchor: "installation" },
      { title: "Global flags",       anchor: "global-flags" },
      { title: "Configuration",      anchor: "configuration" },
      { title: "First conversation", anchor: "first-chat" },
    ]
  },
  {
    title: "CLI Reference",
    items: [
      { title: "halcon chat",        anchor: "chat" },
      { title: "halcon auth",        anchor: "auth" },
      { title: "halcon config",      anchor: "config" },
      { title: "halcon init",        anchor: "init" },
      { title: "halcon status",      anchor: "status" },
      { title: "halcon tools",       anchor: "tools" },
      { title: "halcon memory",      anchor: "memory" },
      { title: "halcon trace",       anchor: "trace" },
      { title: "halcon replay",      anchor: "replay" },
      { title: "halcon metrics",     anchor: "metrics" },
      { title: "halcon doctor",      anchor: "doctor" },
      { title: "halcon update",      anchor: "update" },
      { title: "halcon mcp-server",  anchor: "mcp-server" },
      { title: "halcon serve",       anchor: "serve" },
    ]
  },
  {
    title: "Advanced",
    items: [
      { title: "Feature flags",      anchor: "feature-flags" },
      { title: "TUI Cockpit",        anchor: "tui-cockpit" },
      { title: "Memory system",      anchor: "memory-system" },
      { title: "Slash commands",     anchor: "slash-commands" },
      { title: "Provider setup",     anchor: "providers" },
      { title: "Tool permissions",   anchor: "permissions" },
    ]
  },
];
---

<Layout
  title={t(lang, 'meta.docs.title')}
  description={t(lang, 'meta.docs.desc')}
  lang={lang}
>
  <div class="pt-20 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 py-12 flex gap-12">

      <!-- Sidebar -->
      <aside class="hidden lg:block w-56 shrink-0">
        <div class="sticky top-24 space-y-6">
          {sections.map(s => (
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--c-t4);">{s.title}</h3>
              <ul class="space-y-1">
                {s.items.map(item => (
                  <li>
                    <a href={`#${item.anchor}`}
                       class="block text-sm py-0.5 transition-colors"
                       style="color: var(--c-t3);"
                       onmouseover="this.style.color='var(--c-t1)'"
                       onmouseout="this.style.color='var(--c-t3)'">
                      {item.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </aside>

      <!-- Content -->
      <main class="flex-1 max-w-3xl min-w-0">

        <div class="mb-10">
          <h1 class="text-4xl font-bold mb-3">Documentation</h1>
          <p class="text-lg" style="color: var(--c-t3);">
            Everything you need to install, configure, and get full use out of Halcón CLI.
          </p>
        </div>

        <!-- ══════════════════════════════════════════
             INSTALLATION
        ═══════════════════════════════════════════ -->
        <section id="installation" class="mb-14 scroll-mt-24">
          <h2 class="text-2xl font-bold mb-4 pb-3 border-b" style="border-color: var(--c-b);">Installation</h2>

          <h3 class="text-lg font-semibold mb-3" style="color: var(--c-t1);">Quick install (recommended)</h3>
          <div class="rounded-xl p-4 mb-3" style="background: var(--c-code); border: 1px solid var(--c-b);">
            <div class="text-xs mb-2" style="color: var(--c-t4);">macOS / Linux</div>
            <code class="font-mono text-sm" style="color: var(--c-emerald);">curl -sSfL https://halcon.cuervo.cloud/install.sh | sh</code>
          </div>
          <div class="rounded-xl p-4 mb-4" style="background: var(--c-code); border: 1px solid var(--c-b);">
            <div class="text-xs mb-2" style="color: var(--c-t4);">Windows (PowerShell)</div>
            <code class="font-mono text-sm" style="color: var(--c-p);">iwr -useb https://halcon.cuervo.cloud/install.ps1 | iex</code>
          </div>
          <p class="text-sm mb-5 leading-relaxed" style="color: var(--c-t3);">
            The installer detects your platform, downloads the correct binary, verifies the SHA-256 checksum,
            and places it in <code class="px-1.5 py-0.5 rounded text-xs font-mono" style="color: var(--c-t1); background: var(--c-surface);">~/.local/bin/halcon</code>.
            No sudo required.
          </p>

          <h3 class="text-lg font-semibold mb-3" style="color: var(--c-t1);">Other methods</h3>
          <div class="space-y-3">
            <div class="rounded-xl p-4" style="background: var(--c-code); border: 1px solid var(--c-b);">
              <div class="text-xs mb-2" style="color: var(--c-t4);">Homebrew (macOS / Linux)</div>
              <code class="font-mono text-sm" style="color: var(--c-gold);">brew tap cuervo-ai/tap && brew install halcon</code>
            </div>
            <div class="rounded-xl p-4" style="background: var(--c-code); border: 1px solid var(--c-b);">
              <div class="text-xs mb-2" style="color: var(--c-t4);">Specific version</div>
              <code class="font-mono text-sm" style="color: var(--c-emerald);">curl -sSfL https://halcon.cuervo.cloud/install.sh | sh -s -- --version v0.3.0</code>
            </div>
          </div>
        </section>

        <!-- ══════════════════════════════════════════
             GLOBAL FLAGS
        ═══════════════════════════════════════════ -->
        <section id="global-flags" class="mb-14 scroll-mt-24">
          <h2 class="text-2xl font-bold mb-4 pb-3 border-b" style="border-color: var(--c-b);">Global flags</h2>
          <p class="text-sm mb-4 leading-relaxed" style="color: var(--c-t3);">
            Global flags go <strong>before</strong> the subcommand and apply to the entire session.
            Most have environment variable equivalents.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-7" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div><span style="color: var(--c-emerald);">halcon</span> [GLOBAL FLAGS] &lt;command&gt; [OPTIONS]</div>
            <div class="mt-3 mb-1" style="color: var(--c-t4);">Provider and model:</div>
            <div>  <span style="color: var(--c-gold);">-p, --provider</span> &lt;name&gt;    AI provider to use  <span style="color: var(--c-t4);">(env: HALCON_PROVIDER)</span></div>
            <div>  <span style="color: var(--c-gold);">-m, --model</span> &lt;name&gt;       Model to use  <span style="color: var(--c-t4);">(env: HALCON_MODEL)</span></div>
            <div class="mt-3 mb-1" style="color: var(--c-t4);">Config and logging:</div>
            <div>  <span style="color: var(--c-gold);">--config</span> &lt;path&gt;          Use custom config file  <span style="color: var(--c-t4);">(env: HALCON_CONFIG)</span></div>
            <div>  <span style="color: var(--c-gold);">--log-level</span> &lt;level&gt;      Verbosity: error · warn · info · debug  <span style="color: var(--c-t4);">(env: HALCON_LOG)</span></div>
            <div>  <span style="color: var(--c-gold);">-v, --verbose</span>             Enable debug output</div>
            <div>  <span style="color: var(--c-gold);">--trace-json</span>              Write JSON trace lines to stderr</div>
            <div>  <span style="color: var(--c-gold);">--no-banner</span>               Suppress the startup banner</div>
          </div>
          <p class="mt-3 text-xs" style="color: var(--c-t4);">
            Example: <code class="font-mono" style="color: var(--c-t2);">halcon -p openai -m gpt-4o chat "refactor this function"</code>
          </p>
        </section>

        <!-- ══════════════════════════════════════════
             CONFIGURATION
        ═══════════════════════════════════════════ -->
        <section id="configuration" class="mb-14 scroll-mt-24">
          <h2 class="text-2xl font-bold mb-4 pb-3 border-b" style="border-color: var(--c-b);">Configuration</h2>
          <p class="mb-4 text-sm leading-relaxed" style="color: var(--c-t3);">
            Halcón reads configuration from <code class="px-1.5 py-0.5 rounded text-xs font-mono" style="color: var(--c-t1); background: var(--c-surface);">~/.halcon/config.toml</code> (global)
            and <code class="px-1.5 py-0.5 rounded text-xs font-mono" style="color: var(--c-t1); background: var(--c-surface);">./.halcon/config.toml</code> (project override).
            On first run a default config is created automatically.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-6" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div style="color: var(--c-t4);"># ~/.halcon/config.toml</div>
            <div class="mt-2">[<span style="color: var(--c-p);">general</span>]</div>
            <div><span style="color: var(--c-gold);">default_provider</span> = <span style="color: var(--c-emerald);">"anthropic"</span>  <span style="color: var(--c-t4);"># anthropic · openai · deepseek · gemini · ollama</span></div>
            <div><span style="color: var(--c-gold);">default_model</span>    = <span style="color: var(--c-emerald);">"claude-sonnet-4-5-20250929"</span></div>
            <div class="mt-2">[<span style="color: var(--c-p);">agent.limits</span>]</div>
            <div><span style="color: var(--c-gold);">max_rounds</span>            = <span style="color: var(--c-ember);">25</span></div>
            <div><span style="color: var(--c-gold);">max_tool_output_chars</span> = <span style="color: var(--c-ember);">100000</span></div>
            <div><span style="color: var(--c-gold);">max_parallel_tools</span>    = <span style="color: var(--c-ember);">10</span></div>
            <div class="mt-2">[<span style="color: var(--c-p);">tools</span>]</div>
            <div><span style="color: var(--c-gold);">confirm_destructive</span>  = <span style="color: var(--c-ember);">true</span></div>
            <div><span style="color: var(--c-gold);">allowed_directories</span>  = [<span style="color: var(--c-emerald);">"~/"</span>, <span style="color: var(--c-emerald);">"/tmp"</span>]</div>
            <div><span style="color: var(--c-gold);">blocked_patterns</span>     = [<span style="color: var(--c-emerald);">"**/.env"</span>, <span style="color: var(--c-emerald);">"**/*.key"</span>, <span style="color: var(--c-emerald);">"**/*.pem"</span>]</div>
            <div class="mt-2">[<span style="color: var(--c-p);">agent.routing</span>]</div>
            <div><span style="color: var(--c-gold);">strategy</span> = <span style="color: var(--c-emerald);">"balanced"</span>  <span style="color: var(--c-t4);"># balanced · fast · cheap</span></div>
            <div class="mt-2">[<span style="color: var(--c-p);">display</span>]</div>
            <div><span style="color: var(--c-gold);">ui_mode</span> = <span style="color: var(--c-emerald);">"simple"</span>  <span style="color: var(--c-t4);"># simple · expert</span></div>
          </div>
          <p class="mt-3 text-xs" style="color: var(--c-t4);">
            Override at runtime: <code class="font-mono" style="color: var(--c-t2);">halcon config set general.default_provider openai</code>
          </p>
        </section>

        <!-- ══════════════════════════════════════════
             FIRST CONVERSATION
        ═══════════════════════════════════════════ -->
        <section id="first-chat" class="mb-14 scroll-mt-24">
          <h2 class="text-2xl font-bold mb-4 pb-3 border-b" style="border-color: var(--c-b);">First conversation</h2>
          <div class="space-y-3 text-sm">
            {[
              { n: "1", label: "Add your API key",    cmd: "halcon auth login anthropic",             note: "" },
              { n: "2", label: "Verify it works",     cmd: 'halcon chat "What is 2+2?"',              note: "" },
              { n: "3", label: "Try the TUI cockpit", cmd: "halcon chat --tui",                       note: "" },
              { n: "4", label: "Unlock everything",   cmd: 'halcon chat --full "explain this codebase"', note: "Enables orchestration, reflexion, structured tasks, and expert feedback." },
            ].map(s => (
              <div class="flex items-start gap-3">
                <div class={`w-6 h-6 rounded-md text-xs flex items-center justify-center shrink-0 mt-0.5 font-mono ${s.n === '4' ? '' : ''}`}
                     style={s.n === '4' ? 'background: var(--c-surface); color: var(--c-p); border: 1px solid rgba(232,82,0,0.35);' : 'background: var(--c-surface); color: var(--c-t3); border: 1px solid var(--c-b);'}>{s.n}</div>
                <div>
                  <div class="mb-1.5" style="color: var(--c-t1);">{s.label}</div>
                  <div class="rounded-lg p-3" style="background: var(--c-code); border: 1px solid var(--c-b);">
                    <code class="font-mono text-xs" style={s.n === '4' ? 'color: var(--c-p);' : 'color: var(--c-emerald);'}>{s.cmd}</code>
                  </div>
                  {s.note && <p class="text-xs mt-1.5" style="color: var(--c-t4);">{s.note}</p>}
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- ══════════════════════════════════════════
             CLI REFERENCE
        ═══════════════════════════════════════════ -->
        <section id="chat" class="mb-2 scroll-mt-24">
          <h2 class="text-2xl font-bold mb-6 pb-3 border-b" style="border-color: var(--c-b);">CLI Reference</h2>
        </section>

        <!-- halcon chat -->
        <div class="mb-10 scroll-mt-24">
          <h3 class="text-lg font-bold mb-1 font-mono" style="color: var(--c-p);">halcon chat</h3>
          <p class="text-sm mb-3" style="color: var(--c-t3);">
            Start an AI session with full tool access. Pass a prompt for single-shot mode or omit it for the interactive REPL.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-7" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div><span style="color: var(--c-emerald);">halcon chat</span> [OPTIONS] [PROMPT]</div>
            <div class="mt-2" style="color: var(--c-t4);">Core flags:</div>
            <div>  <span style="color: var(--c-gold);">--tui</span>                   Launch 3-zone TUI cockpit</div>
            <div>  <span style="color: var(--c-gold);">--provider</span> &lt;name&gt;       Override provider for this session</div>
            <div>  <span style="color: var(--c-gold);">--model</span> &lt;name&gt;          Override model for this session</div>
            <div>  <span style="color: var(--c-gold);">--resume</span> &lt;session-id&gt;   Resume a previous session by UUID</div>
            <div>  <span style="color: var(--c-gold);">--expert</span>                 Show verbose agent feedback</div>
            <div class="mt-2" style="color: var(--c-t4);">Advanced features (or use --full for all):</div>
            <div>  <span style="color: var(--c-p);">--full</span>                   Orchestration + reflexion + tasks + expert output</div>
            <div>  <span style="color: var(--c-p);">--orchestrate</span>            Multi-agent orchestration with wave scheduling</div>
            <div>  <span style="color: var(--c-p);">--reflexion</span>              Self-improvement loop before responding</div>
            <div>  <span style="color: var(--c-p);">--tasks</span>                  Structured task framework with FSM tracking</div>
            <div class="mt-2" style="color: var(--c-t4);">Observability:</div>
            <div>  <span style="color: var(--c-emerald);">--metrics</span>               Print session metrics on exit</div>
            <div>  <span style="color: var(--c-emerald);">--timeline</span>              Export execution timeline as JSON on exit</div>
            <div>  <span style="color: var(--c-emerald);">--trace-out</span> &lt;path&gt;     Write JSONL trace (replayable with --trace-in)</div>
            <div>  <span style="color: var(--c-emerald);">--trace-in</span> &lt;path&gt;      Replay a JSONL trace before the session</div>
          </div>
        </div>

        <!-- halcon auth -->
        <div id="auth" class="mb-10 scroll-mt-24">
          <h3 class="text-lg font-bold mb-1 font-mono" style="color: var(--c-p);">halcon auth</h3>
          <p class="text-sm mb-3" style="color: var(--c-t3);">
            Manage API keys. Keys are stored in the OS keychain — never written to disk in plaintext.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-7" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div><span style="color: var(--c-emerald);">halcon auth login</span> &lt;provider&gt;    Store API key in system keychain</div>
            <div><span style="color: var(--c-emerald);">halcon auth logout</span> &lt;provider&gt;   Remove API key from keychain</div>
            <div><span style="color: var(--c-emerald);">halcon auth status</span>               Show which providers have keys configured</div>
            <div class="mt-2" style="color: var(--c-t4);">Providers: anthropic · openai · deepseek · gemini  <span style="color: var(--c-t4);">(ollama needs no key)</span></div>
          </div>
        </div>

        <!-- halcon config -->
        <div id="config" class="mb-10 scroll-mt-24">
          <h3 class="text-lg font-bold mb-1 font-mono" style="color: var(--c-p);">halcon config</h3>
          <p class="text-sm mb-3" style="color: var(--c-t3);">
            Read and write configuration values without editing the TOML file manually.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-7" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div><span style="color: var(--c-emerald);">halcon config show</span>                         Print all active config (merged global + project)</div>
            <div><span style="color: var(--c-emerald);">halcon config path</span>                         Show the config file path in use</div>
            <div><span style="color: var(--c-emerald);">halcon config get</span> &lt;key&gt;                    Read a single value  <span style="color: var(--c-t4);">e.g. general.default_provider</span></div>
            <div><span style="color: var(--c-emerald);">halcon config set</span> &lt;key&gt; &lt;value&gt;             Write a value to the global config</div>
          </div>
        </div>

        <!-- halcon init -->
        <div id="init" class="mb-10 scroll-mt-24">
          <h3 class="text-lg font-bold mb-1 font-mono" style="color: var(--c-p);">halcon init</h3>
          <p class="text-sm mb-3" style="color: var(--c-t3);">
            Initialize Halcón in the current project directory. Creates a <code class="font-mono text-xs" style="color: var(--c-t1);">.halcon/config.toml</code> override.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-7" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div><span style="color: var(--c-emerald);">halcon init</span>                                Create .halcon/config.toml in current directory</div>
            <div><span style="color: var(--c-emerald);">halcon init --provider openai</span>              Initialize with OpenAI as default provider</div>
          </div>
        </div>

        <!-- halcon status -->
        <div id="status" class="mb-10 scroll-mt-24">
          <h3 class="text-lg font-bold mb-1 font-mono" style="color: var(--c-p);">halcon status</h3>
          <p class="text-sm mb-3" style="color: var(--c-t3);">
            Show the current system status: active provider and model, session count, version, and keychain state.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-7" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div><span style="color: var(--c-emerald);">halcon status</span>                              Print provider, model, session count, binary version</div>
          </div>
        </div>

        <!-- halcon tools -->
        <div id="tools" class="mb-10 scroll-mt-24">
          <h3 class="text-lg font-bold mb-1 font-mono" style="color: var(--c-p);">halcon tools</h3>
          <p class="text-sm mb-3" style="color: var(--c-t3);">
            Inspect and manage the 21 built-in tools. Add custom tools via TOML manifests stored at
            <code class="font-mono text-xs" style="color: var(--c-t1);">~/.halcon/tools/&lt;name&gt;.toml</code>.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-7" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div><span style="color: var(--c-emerald);">halcon tools list</span>                          List all tools with names and permission levels</div>
            <div><span style="color: var(--c-emerald);">halcon tools validate</span>                      Deep schema validation for all registered tools</div>
            <div><span style="color: var(--c-emerald);">halcon tools doctor</span>                        Health diagnostics: schema, probes, error metrics</div>
            <div><span style="color: var(--c-emerald);">halcon tools add</span> &lt;name&gt; \</div>
            <div>  --command &lt;cmd&gt; --description &lt;desc&gt; [--permission ReadOnly|Destructive]</div>
            <div><span style="color: var(--c-emerald);">halcon tools remove</span> &lt;name&gt; [--force]      Remove a custom tool manifest</div>
          </div>
        </div>

        <!-- halcon memory -->
        <div id="memory" class="mb-10 scroll-mt-24">
          <h3 class="text-lg font-bold mb-1 font-mono" style="color: var(--c-p);">halcon memory</h3>
          <p class="text-sm mb-3" style="color: var(--c-t3);">
            Query and manage the episodic memory store. The agent automatically reads relevant memory before each response using BM25 semantic search.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-7" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div><span style="color: var(--c-emerald);">halcon memory search</span> &lt;query&gt; [--limit N]  BM25 full-text search across all entries</div>
            <div><span style="color: var(--c-emerald);">halcon memory list</span> [--type &lt;type&gt;]        List entries, optionally filtered by type</div>
            <div><span style="color: var(--c-emerald);">halcon memory stats</span>                        Show counts and total storage size</div>
            <div><span style="color: var(--c-emerald);">halcon memory prune</span> [--force]             Remove expired and low-relevance entries</div>
            <div class="mt-2" style="color: var(--c-t4);">Entry types: fact · session_summary · decision · code_snippet · project_meta</div>
          </div>
        </div>

        <!-- halcon trace -->
        <div id="trace" class="mb-10 scroll-mt-24">
          <h3 class="text-lg font-bold mb-1 font-mono" style="color: var(--c-p);">halcon trace</h3>
          <p class="text-sm mb-3" style="color: var(--c-t3);">
            Inspect and export session traces. Traces are human-readable JSONL files capturing every agent round, tool call, and model response.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-7" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
