          </div>
        </div>

        <!-- halcon update -->
        <div id="update" class="mb-10 scroll-mt-24">
          <h3 class="text-lg font-bold mb-1 font-mono" style="color: var(--c-p);">halcon update</h3>
          <p class="text-sm mb-3" style="color: var(--c-t3);">
            Self-update: fetches the latest release manifest from <code class="font-mono text-xs" style="color: var(--c-t1);">cli.cuervo.cloud</code>, verifies the SHA-256 checksum, and replaces the binary atomically.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-7" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div><span style="color: var(--c-emerald);">halcon update</span>                              Download and install the latest release</div>
            <div><span style="color: var(--c-emerald);">halcon update --check</span>                      Report if a newer version is available</div>
            <div><span style="color: var(--c-emerald);">halcon update --version v0.3.0</span>             Install a specific release</div>
            <div><span style="color: var(--c-emerald);">halcon update --force</span>                      Reinstall even if already on latest version</div>
          </div>
        </div>

        <!-- halcon mcp-server -->
