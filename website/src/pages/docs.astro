        <!-- ══════════════════════════════════════════
             MEMORY SYSTEM
        ═══════════════════════════════════════════ -->
        <section id="memory-system" class="mb-14 scroll-mt-24">
          <h2 class="text-2xl font-bold mb-4 pb-3 border-b" style="border-color: var(--c-b);">Memory system</h2>
          <p class="text-sm mb-5 leading-relaxed" style="color: var(--c-t3);">
            Halcón manages context automatically using a 5-tier memory architecture. You never need to configure it —
            the agent decides what to keep, compress, and retrieve based on relevance and token budgets.
          </p>

          <h3 class="text-base font-semibold mb-3" style="color: var(--c-t1);">Context tiers (active session)</h3>
          <div class="rounded-xl overflow-hidden mb-6" style="background: var(--c-code); border: 1px solid var(--c-b);">
            {[
              { tier: "L0", name: "HotBuffer",     pct: "40%", desc: "Ring buffer of the most recent messages. Always included in every request." },
              { tier: "L1", name: "SlidingWindow", pct: "25%", desc: "Compacted conversation segments. Older messages are merged and summarized." },
              { tier: "L2", name: "ColdStore",     pct: "15%", desc: "zstd-compressed segments with delta encoding. Retrieved when budget allows." },
              { tier: "L3", name: "SemanticStore", pct: "15%", desc: "BM25-indexed retrieval. The most relevant past context for the current query." },
              { tier: "L4", name: "ColdArchive",   pct: "5%",  desc: "Disk-persisted archive (~/.local/share/halcon/l4_archive.bin). Cross-session." },
            ].map((t, i) => (
              <div class={`flex gap-4 px-4 py-3 font-mono text-xs ${i > 0 ? 'border-t' : ''}`}
                   style={i > 0 ? 'border-color: rgba(200,80,0,0.08);' : ''}>
                <span class="shrink-0 font-bold" style="color: var(--c-p); width:2rem">{t.tier}</span>
                <span class="shrink-0" style="color: var(--c-gold); width:8rem">{t.name}</span>
                <span class="shrink-0" style="color: var(--c-t4); width:2.5rem">{t.pct}</span>
                <span style="color: var(--c-t3);">{t.desc}</span>
              </div>
            ))}
          </div>

          <h3 class="text-base font-semibold mb-3" style="color: var(--c-t1);">Episodic memory (cross-session)</h3>
          <p class="text-sm mb-3 leading-relaxed" style="color: var(--c-t3);">
            Stored in <code class="font-mono text-xs px-1 rounded" style="color: var(--c-t1); background: var(--c-surface);">~/.halcon/halcon.db</code> using SQLite with FTS5 full-text index.
            The agent automatically records decisions, code patterns, and important facts, then retrieves the most relevant entries before each response.
          </p>
          <div class="rounded-xl p-4 font-mono text-xs leading-6" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div style="color: var(--c-t4);">Retrieval: BM25 semantic search on current query</div>
            <div style="color: var(--c-t4);">Scoring:   relevance_score × temporal decay (14-day half-life)</div>
            <div style="color: var(--c-t4);">Feedback:  successful rounds boost score +0.2 · failures decay −0.15</div>
            <div style="color: var(--c-t4);">Cleanup:   auto-consolidation merges similar entries (Jaccard similarity)</div>
          </div>
        </section>

