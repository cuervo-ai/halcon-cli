            <div style="color: var(--c-t4);"># Routing strategies (agent.routing.strategy):</div>
            <div>  <span style="color: var(--c-gold);">balanced</span>  Cost/quality tradeoff — default. Routes to best-fit model per task.</div>
            <div>  <span style="color: var(--c-gold);">fast</span>      Lowest latency. Prioritizes by p95 response time from past metrics.</div>
            <div>  <span style="color: var(--c-gold);">cheap</span>     Lowest cost per token. Always routes to the cheapest capable model.</div>
          </div>
        </section>

        <!-- ══════════════════════════════════════════
             TOOL PERMISSIONS
        ═══════════════════════════════════════════ -->
        <section id="permissions" class="mb-14 scroll-mt-24">
          <h2 class="text-2xl font-bold mb-4 pb-3 border-b" style="border-color: var(--c-b);">Tool permissions</h2>
          <p class="text-sm mb-5 leading-relaxed" style="color: var(--c-t3);">
            Every tool carries an explicit permission level. Destructive tools show a confirmation prompt before executing.
            Set <code class="font-mono text-xs" style="color: var(--c-t1);">tools.confirm_destructive = false</code> to disable in CI/automated pipelines.
          </p>
          <div class="space-y-4">
            {[
              {
                level: "ReadOnly",
                color: "var(--c-emerald)",
                note: "Never prompts — safe read operations",
                tools: "file_read · directory_tree · glob · grep · fuzzy_find · symbol_search · web_fetch · web_search · native_search · git_status · git_diff · git_log · file_inspect · background_output · task_track",
              },
              {
                level: "ReadWrite",
                color: "var(--c-gold)",
                note: "No confirmation — reversible writes",
                tools: "git_add",
              },
              {
                level: "Destructive",
                color: "var(--c-ember)",
                note: "Prompts before executing (confirm_destructive = true)",
                tools: "bash · file_write · file_edit · file_delete · git_commit · http_request · background_start · background_kill",
              },
            ].map(p => (
              <div class="p-4 rounded-xl" style="background: var(--c-code); border: 1px solid var(--c-b);">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-xs font-bold font-mono px-2 py-0.5 rounded" style={`color: ${p.color}; border: 1px solid ${p.color}; opacity: 0.9;`}>{p.level}</span>
                  <span class="text-xs" style="color: var(--c-t4);">{p.note}</span>
                </div>
                <div class="text-xs font-mono leading-relaxed" style="color: var(--c-t3);">{p.tools}</div>
              </div>
            ))}
          </div>
        </section>

        <!-- ══════════════════════════════════════════
             HELP
        ═══════════════════════════════════════════ -->
        <div class="rounded-2xl p-6" style="background: rgba(232,82,0,0.06); border: 1px solid rgba(232,82,0,0.20);">
          <h3 class="font-bold mb-3" style="color: var(--c-p);">Need help?</h3>
          <div class="space-y-2 text-sm">
            <div>
              <a href="mailto:support@cuervo.cloud"
                 class="transition-colors" style="color: var(--c-gold);"
                 onmouseover="this.style.color='var(--c-t1)'"
                 onmouseout="this.style.color='var(--c-gold)'">
                support@cuervo.cloud
              </a>
              <span class="ml-2" style="color: var(--c-t4);">— Questions, bug reports, feature requests</span>
            </div>
            <div>
              <code class="font-mono text-xs" style="color: var(--c-t2);">halcon doctor</code>
              <span class="ml-2" style="color: var(--c-t4);">— Run diagnostics first, attach the output to your report</span>
            </div>
          </div>
        </div>

      </main>
    </div>
  </div>
</Layout>
