        <!-- ══════════════════════════════════════════
             PROVEEDORES
        ═══════════════════════════════════════════ -->
        <section id="providers" class="mb-14 scroll-mt-24">
          <h2 class="text-2xl font-bold mb-4 pb-3 border-b" style="border-color: var(--c-b);">Configuración de proveedores</h2>
          <p class="text-sm mb-5 leading-relaxed" style="color: var(--c-t3);">
            Las claves API se guardan en el keychain del OS via <code class="font-mono text-xs px-1 py-0.5 rounded" style="color: var(--c-t1); background: var(--c-surface);">halcon auth login</code>.
            La estrategia de routing (<code class="font-mono text-xs" style="color: var(--c-t1);">balanced · fast · cheap</code>) elige entre los proveedores configurados automáticamente.
          </p>

          <div class="space-y-3">
            {[
              {
                provider: "Anthropic",
                key: "ANTHROPIC_API_KEY",
                models: [
                  { id: "claude-opus-4-6",            ctx: "200K", caps: "visión · herramientas" },
                  { id: "claude-sonnet-4-5-20250929",  ctx: "200K", caps: "visión · herramientas" },
                  { id: "claude-haiku-4-5-20251001",   ctx: "200K", caps: "visión · herramientas" },
                ],
              },
              {
                provider: "OpenAI",
                key: "OPENAI_API_KEY",
                models: [
                  { id: "gpt-4o",      ctx: "128K", caps: "visión · herramientas · razonamiento" },
                  { id: "gpt-4o-mini", ctx: "128K", caps: "visión · herramientas" },
                  { id: "o1",          ctx: "200K", caps: "razonamiento (sin visión)" },
                  { id: "o3-mini",     ctx: "200K", caps: "razonamiento (sin visión)" },
                ],
              },
              {
                provider: "DeepSeek",
                key: "DEEPSEEK_API_KEY",
                models: [
                  { id: "deepseek-chat",     ctx: "64K", caps: "herramientas" },
                  { id: "deepseek-coder",    ctx: "64K", caps: "herramientas" },
                  { id: "deepseek-reasoner", ctx: "64K", caps: "herramientas · razonamiento" },
                ],
              },
              {
                provider: "Gemini",
                key: "GEMINI_API_KEY",
                models: [
                  { id: "gemini-2.0-flash", ctx: "1M",  caps: "visión · herramientas" },
                  { id: "gemini-1.5-pro",   ctx: "1M",  caps: "visión · herramientas" },
                ],
              },
              {
                provider: "Ollama",
                key: "(sin clave requerida)",
                models: [
                  { id: "cualquier modelo instalado", ctx: "variable", caps: "emulación de herramientas vía XML en system prompt" },
                ],
              },
            ].map(p => (
              <div class="p-4 rounded-xl" style="background: var(--c-surface); border: 1px solid var(--c-b);">
                <div class="flex items-center justify-between mb-3">
                  <span class="font-bold text-sm" style="color: var(--c-t1);">{p.provider}</span>
                  <code class="text-xs font-mono" style="color: var(--c-t4);">{p.key}</code>
                </div>
                <div class="space-y-1">
                  {p.models.map(m => (
                    <div class="flex items-center gap-3 font-mono text-xs">
                      <span style="color: var(--c-gold); min-width:16rem">{m.id}</span>
                      <span style="color: var(--c-t4); min-width:3rem">{m.ctx}</span>
                      <span style="color: var(--c-t4);">{m.caps}</span>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>

          <div class="mt-4 rounded-xl p-4 font-mono text-xs leading-6" style="background: var(--c-code); border: 1px solid var(--c-b); color: var(--c-t3);">
            <div style="color: var(--c-t4);"># Estrategias de routing (agent.routing.strategy):</div>
            <div>  <span style="color: var(--c-gold);">balanced</span>  Balance coste/calidad — por defecto. Enruta al modelo más adecuado por tarea.</div>
            <div>  <span style="color: var(--c-gold);">fast</span>      Menor latencia. Prioriza por tiempo de respuesta p95 de métricas históricas.</div>
            <div>  <span style="color: var(--c-gold);">cheap</span>     Menor coste por token. Siempre enruta al modelo capaz más económico.</div>
          </div>
        </section>

        <!-- ══════════════════════════════════════════
             PERMISOS DE HERRAMIENTAS
        ═══════════════════════════════════════════ -->
        <section id="permissions" class="mb-14 scroll-mt-24">
          <h2 class="text-2xl font-bold mb-4 pb-3 border-b" style="border-color: var(--c-b);">Permisos de herramientas</h2>
          <p class="text-sm mb-5 leading-relaxed" style="color: var(--c-t3);">
            Cada herramienta tiene un nivel de permiso explícito. Las herramientas Destructive solicitan confirmación antes de ejecutarse.
            Configura <code class="font-mono text-xs" style="color: var(--c-t1);">tools.confirm_destructive = false</code> para deshabilitar en pipelines CI/automatizados.
          </p>
          <div class="space-y-4">
            {[
              {
                level: "ReadOnly",
                color: "var(--c-emerald)",
                note: "Nunca solicita confirmación — operaciones de solo lectura seguras",
                tools: "file_read · directory_tree · glob · grep · fuzzy_find · symbol_search · web_fetch · web_search · native_search · git_status · git_diff · git_log · file_inspect · background_output · task_track",
              },
              {
                level: "ReadWrite",
                color: "var(--c-gold)",
                note: "Sin confirmación — escrituras reversibles",
                tools: "git_add",
              },
              {
                level: "Destructive",
                color: "var(--c-ember)",
                note: "Solicita confirmación antes de ejecutar (confirm_destructive = true)",
                tools: "bash · file_write · file_edit · file_delete · git_commit · http_request · background_start · background_kill",
              },
            ].map(p => (
              <div class="p-4 rounded-xl" style="background: var(--c-code); border: 1px solid var(--c-b);">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-xs font-bold font-mono px-2 py-0.5 rounded" style={`color: ${p.color}; border: 1px solid ${p.color}; opacity: 0.9;`}>{p.level}</span>
                  <span class="text-xs" style="color: var(--c-t4);">{p.note}</span>
                </div>
                <div class="text-xs font-mono leading-relaxed" style="color: var(--c-t3);">{p.tools}</div>
              </div>
            ))}
          </div>
        </section>

        <!-- ══════════════════════════════════════════
             AYUDA
        ═══════════════════════════════════════════ -->
        <div class="rounded-2xl p-6" style="background: rgba(232,82,0,0.06); border: 1px solid rgba(232,82,0,0.20);">
          <h3 class="font-bold mb-3" style="color: var(--c-p);">¿Necesitas más ayuda?</h3>
          <div class="space-y-2 text-sm">
            <div>
              <a href="mailto:support@cuervo.cloud"
                 class="transition-colors" style="color: var(--c-gold);"
                 onmouseover="this.style.color='var(--c-t1)'"
                 onmouseout="this.style.color='var(--c-gold)'">
                support@cuervo.cloud
              </a>
              <span class="ml-2" style="color: var(--c-t4);">— Preguntas, reporte de bugs, solicitudes de funciones</span>
            </div>
            <div>
              <code class="font-mono text-xs" style="color: var(--c-t2);">halcon doctor</code>
              <span class="ml-2" style="color: var(--c-t4);">— Ejecuta diagnósticos primero y adjunta la salida a tu reporte</span>
            </div>
          </div>
        </div>

      </main>
    </div>
  </div>
</Layout>
