---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/translations';

const lang = 'es';

const providers = [
  {
    name: 'Anthropic',
    logo: '🧠',
    accent: 'rgba(232,82,0,0.10)',
    border: 'rgba(232,82,0,0.30)',
    models: ['Claude Opus 4.6', 'Claude Sonnet 4.5', 'Claude Haiku 4.5'],
    badge: null,
  },
  {
    name: 'OpenAI',
    logo: '⬡',
    accent: 'rgba(16,163,127,0.10)',
    border: 'rgba(16,163,127,0.28)',
    models: ['GPT-4o', 'GPT-4o mini', 'o1', 'o3-mini'],
    badge: null,
  },
  {
    name: 'DeepSeek',
    logo: '◎',
    accent: 'rgba(99,102,241,0.10)',
    border: 'rgba(99,102,241,0.28)',
    models: ['deepseek-chat', 'deepseek-coder', 'deepseek-reasoner'],
    badge: null,
  },
  {
    name: 'Google Gemini',
    logo: '✦',
    accent: 'rgba(66,133,244,0.10)',
    border: 'rgba(66,133,244,0.28)',
    models: ['Gemini 2.0 Flash', 'Gemini 2.5 Pro'],
    badge: null,
  },
  {
    name: 'Ollama',
    logo: '⬤',
    accent: 'rgba(245,160,0,0.08)',
    border: 'rgba(245,160,0,0.28)',
    models: ['Llama 3', 'Mistral', 'DeepSeek Coder V2', '+ cualquier modelo'],
    badge: t(lang, 'providers.local_badge'),
  },
];

const features = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
    title: t(lang, 'f1.title'),
    desc: t(lang, 'f1.desc'),
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
    title: t(lang, 'f2.title'),
    desc: t(lang, 'f2.desc'),
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
    title: t(lang, 'f3.title'),
    desc: t(lang, 'f3.desc'),
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>`,
    title: t(lang, 'f4.title'),
    desc: t(lang, 'f4.desc'),
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>`,
    title: t(lang, 'f5.title'),
    desc: t(lang, 'f5.desc'),
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
    title: t(lang, 'f6.title'),
    desc: t(lang, 'f6.desc'),
  },
];
---

<Layout
  title={t(lang, 'meta.index.title')}
  description={t(lang, 'meta.index.desc')}
  lang={lang}
>

  <!-- ═══════════════════════════════════════════ HERO ══ -->
  <section class="relative min-h-[90vh] flex flex-col items-center justify-center pt-24 pb-16 px-4 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full opacity-20"
           style="background: radial-gradient(circle, rgba(232,82,0,0.5) 0%, rgba(245,160,0,0.2) 40%, transparent 70%); filter: blur(80px);"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-8 rounded-full border text-xs font-medium font-mono"
           style="border-color: rgba(232,82,0,0.35); background: rgba(232,82,0,0.08); color: var(--c-gold);">
        <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background: var(--c-p);"></span>
        v0.3.0 · macOS · Linux · Windows
      </div>

      <h1 class="text-5xl sm:text-6xl md:text-7xl font-black leading-none tracking-tight mb-6 font-display">
        {t(lang, 'hero.headline').split('\n').map((line: string, i: number) => (
          <span class={i === 1 ? 'block gradient-text-brand mt-1' : 'block'}>{line}</span>
        ))}
      </h1>

      <p class="text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto mb-10" style="color: var(--c-t2);">
        {t(lang, 'hero.sub')}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-14">
        <a href="/es/download" class="btn-primary" style="padding: 0.875rem 2rem; font-size: 1rem;">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          {t(lang, 'hero.cta_dl')}
        </a>
        <a href="/es/docs"
           class="flex items-center gap-2 px-6 py-3.5 rounded-xl text-sm font-medium border transition-all duration-200"
           style="color: var(--c-t2); border-color: var(--c-b);"
           onmouseover="this.style.color='var(--c-t1)'; this.style.borderColor='var(--c-bh)'"
           onmouseout="this.style.color='var(--c-t2)'; this.style.borderColor='var(--c-b)'">
          {t(lang, 'hero.cta_docs')}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="inline-block max-w-lg w-full">
        <p class="text-xs font-medium mb-2 text-left pl-1" style="color: var(--c-t4);">{t(lang, 'hero.install_label')}</p>
        <div class="glass rounded-xl overflow-hidden text-left">
          <div class="flex items-center justify-between px-4 py-2.5 border-b" style="border-color: var(--c-b); background: var(--c-surface);">
            <div class="flex gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full" style="background: rgba(200,80,0,0.4);"></span>
              <span class="w-2.5 h-2.5 rounded-full" style="background: rgba(245,160,0,0.3);"></span>
              <span class="w-2.5 h-2.5 rounded-full" style="background: rgba(34,197,94,0.3);"></span>
            </div>
            <span class="text-xs font-mono" style="color: var(--c-t4);">bash</span>
          </div>
          <div class="px-4 py-3.5 font-mono text-sm" style="color: var(--c-p);">
            <span style="color: var(--c-t4);">$ </span>curl -sSfL https://halcon.cuervo.cloud/install.sh | sh
          </div>
        </div>
        <p class="text-xs mt-2 text-center" style="color: var(--c-t4);">Verificado con SHA-256 · sin sudo · instala en ~/.local/bin</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ PROVIDERS ══ -->
  <section id="providers" class="py-24 px-4 border-t" style="border-color: var(--c-b);">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-black mb-3 font-display">{t(lang, 'providers.heading')}</h2>
        <p class="text-base" style="color: var(--c-t3);">{t(lang, 'providers.sub')}</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {providers.map(p => (
          <div class="glass rounded-2xl p-5 transition-all duration-300"
               style={`border-color: ${p.border}; background: ${p.accent};`}
               onmouseover="this.style.transform='scale(1.01)'"
               onmouseout="this.style.transform='scale(1)'">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl"
                     style={`background: ${p.accent}; border: 1px solid ${p.border};`}>{p.logo}</div>
                <span class="font-bold text-base" style="color: var(--c-t1);">{p.name}</span>
              </div>
              {p.badge && (
                <span class="text-xs font-medium px-2 py-0.5 rounded-full"
                      style="background: rgba(245,160,0,0.15); color: var(--c-gold); border: 1px solid rgba(245,160,0,0.3);">
                  {p.badge}
                </span>
              )}
            </div>
            <div class="space-y-1.5">
              <p class="text-xs uppercase tracking-wider mb-2" style="color: var(--c-t4);">{t(lang, 'providers.models')}</p>
              {p.models.map(m => (
                <div class="flex items-center gap-2">
                  <span class="w-1 h-1 rounded-full flex-shrink-0" style="background: var(--c-p); opacity: 0.6;"></span>
                  <span class="font-mono text-xs" style="color: var(--c-t2);">{m}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
        <div class="glass rounded-2xl p-5 flex flex-col items-center justify-center text-center gap-3"
             style="border-style: dashed; border-color: rgba(200,80,0,0.25);">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center"
               style="background: rgba(232,82,0,0.08); border: 1px solid rgba(232,82,0,0.2);">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--c-p);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
            </svg>
          </div>
          <p class="text-sm font-medium" style="color: var(--c-t2);">Cambia con un solo flag</p>
          <code class="font-mono text-xs px-3 py-1.5 rounded-lg" style="background: var(--c-surface); color: var(--c-p);">halcon -p openai chat</code>
          <code class="font-mono text-xs px-3 py-1.5 rounded-lg" style="background: var(--c-surface); color: var(--c-gold);">halcon -p ollama -m llama3 chat</code>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ FEATURES ══ -->
  <section id="features" class="py-24 px-4 border-t" style="border-color: var(--c-b);">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-black mb-3 font-display">{t(lang, 'features.heading')}</h2>
        <p class="text-base" style="color: var(--c-t3);">{t(lang, 'features.sub')}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {features.map(f => (
          <div class="glass rounded-2xl p-6 transition-all duration-300"
               onmouseover="this.style.borderColor='var(--c-bh)'; this.style.transform='scale(1.01)'"
               onmouseout="this.style.borderColor=''; this.style.transform='scale(1)'">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
                 style="background: rgba(232,82,0,0.08); border: 1px solid rgba(232,82,0,0.2);">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--c-p);" set:html={f.icon} />
            </div>
            <h3 class="font-bold text-base mb-2" style="color: var(--c-t1);">{f.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--c-t3);">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ QUICK START ══ -->
  <section class="py-24 px-4 border-t" style="border-color: var(--c-b);">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-black mb-3 font-display">{t(lang, 'qs.heading')}</h2>
      </div>
      <div class="space-y-4">
        {[
          { n: '1', title: t(lang, 'qs.step1'), note: t(lang, 'qs.step1_note'), code: 'curl -sSfL https://halcon.cuervo.cloud/install.sh | sh' },
          { n: '2', title: t(lang, 'qs.step2'), note: t(lang, 'qs.step2_note'), code: 'halcon auth login anthropic' },
          { n: '3', title: t(lang, 'qs.step3'), note: t(lang, 'qs.step3_note'), code: 'halcon chat "Refactoriza mi función de login para usar async/await"' },
        ].map(step => (
          <div class="glass rounded-2xl overflow-hidden">
            <div class="flex items-center gap-4 px-5 py-4 border-b" style="border-color: var(--c-b); background: var(--c-surface);">
              <div class="w-7 h-7 rounded-lg flex items-center justify-center text-sm font-mono font-bold flex-shrink-0"
                   style="background: rgba(232,82,0,0.12); color: var(--c-p); border: 1px solid rgba(232,82,0,0.3);">{step.n}</div>
              <div>
                <p class="font-semibold text-sm" style="color: var(--c-t1);">{step.title}</p>
                <p class="text-xs mt-0.5" style="color: var(--c-t4);">{step.note}</p>
              </div>
            </div>
            <div class="px-5 py-4 font-mono text-sm" style="color: var(--c-p);">
              <span style="color: var(--c-t4);">$ </span>{step.code}
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-sm mt-8" style="color: var(--c-t4);">{t(lang, 'qs.all_providers')}</p>
    </div>
  </section>

</Layout>
